---
import { type CollectionEntry, getCollection } from "astro:content";
import BlogPage from "../../layouts/BlogPage.astro";
import HeaderTitle from "../../components/HeaderTitle.astro";
import SpinText from "../../components/SpinText.astro";
import "@fontsource-variable/jetbrains-mono";
import { render } from "astro:content";
import PostedOn from "../../components/PostedOn.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: post,
    }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await render(post);
const {
    title,
    date,
    customFooter,
    customFooterHtml,
    htmlTitle,
    spinFooterText,
} = post.data;
---

<style is:global>
    :root {
        --code-font: "JetBrains Mono Variable", monospace;
    }
    article {
        margin-bottom: 2rem;
    }

    * + section {
        margin-top: 2rem;
    }

    code {
        font-family: var(--code-font);
        font-size: 0.875rem;
    }

    :not(pre) > code {
        background: #eff1f5;
    }

    section li {
        margin: 1rem 0;
    }
</style>

<BlogPage title={title}>
    <article>
        <HeaderTitle title={title} date={date} htmlTitle={htmlTitle} />
        <Content />
    </article>
    <Fragment slot="footer"
        >{
            customFooterHtml ? (
                <Fragment set:html={customFooterHtml} />
            ) : spinFooterText ? (
                <SpinText>{customFooter ?? <PostedOn date={date} />}</SpinText>
            ) : (
                (customFooter ?? <PostedOn date={date} />)
            )
        }</Fragment
    >
</BlogPage>
